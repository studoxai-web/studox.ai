PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret
APP_URL=http://localhost:4000

# Optional. If omitted, the app runs with the built-in in-memory demo data.
MONGO_URI=mongodb://127.0.0.1:27017/studox_ai
MONGO_DB_NAME=studox_ai

# Email OTP configuration for forgot password.
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-character-gmail-app-password
# OTP_FROM="Studox.ai <your-email@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
OTP_FROM="Studox.ai <no-reply@studox.ai>"
OTP_EXPIRY_MINUTES=10

# AI Mentor configuration.
# AI_PROVIDER can be openai, gemini, or blank for local fallback.
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
